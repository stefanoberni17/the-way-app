# ============================================
# The Way — La Via del Cuore
# Variabili d'ambiente (template)
# Copia questo file in .env.local e compila i valori.
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Notion CMS ---
NOTION_TOKEN=
NOTION_DATABASE_SETTIMANE=
NOTION_DATABASE_EPISODI=
# DB "Frasi del giorno" per le notifiche push mattutine
NOTION_DATABASE_FRASI=

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=

# --- Telegram bot (opzionale) ---
TELEGRAM_BOT_TOKEN=

# --- Push notifications (Web Push / VAPID) ---
# Generale con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Tipicamente "mailto:tua@email.com"
VAPID_SUBJECT=

# --- Cron / Infra ---
# Segreto richiesto da /api/cron/cleanup-telegram e /api/cron/daily-verse
# per autorizzare le chiamate dei Vercel Cron Jobs
CRON_SECRET=
